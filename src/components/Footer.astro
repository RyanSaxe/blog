---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--color-border)] px-6 py-8">
  <div class="mx-auto flex max-w-3xl items-center justify-between text-xs text-[var(--color-text-faint)]">
    <span>&copy; {year} Ryan Saxe</span>
    <a
      href="/rss.xml"
      class="transition-colors hover:text-[var(--color-text-muted)]"
    >
      RSS
    </a>
  </div>
</footer>
