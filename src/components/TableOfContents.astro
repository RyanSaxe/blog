---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  filtered.length > 0 && (
    <details
      open
      class="mb-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5"
    >
      <summary class="cursor-pointer font-[var(--font-serif)] text-sm font-semibold text-[var(--color-text)] select-none">
        Table of Contents
      </summary>
      <nav class="mt-3">
        <ul class="space-y-1.5 text-sm">
          {filtered.map((heading) => (
            <li class:list={[heading.depth === 3 && "ml-4"]}>
              <a
                href={`#${heading.slug}`}
                class="text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  )
}
