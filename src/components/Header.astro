---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="border-b border-[var(--color-border)]">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a
      href="/"
      class="font-[var(--font-serif)] text-lg font-semibold tracking-tight text-[var(--color-text)] transition-colors hover:text-[var(--color-accent)]"
    >
      Ryan Saxe's Blog
    </a>

    <div class="flex items-center gap-5">
      <a
        href="/about"
        class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        About
      </a>
      <a
        href="/rss.xml"
        class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        RSS
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
