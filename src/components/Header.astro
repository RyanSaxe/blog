---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="px-6 pt-10 pb-6">
  <nav class="mx-auto flex max-w-3xl items-center justify-between">
    <a
      href="/"
      class="font-[var(--font-serif)] text-xl font-semibold tracking-tight text-[var(--color-text)] transition-colors hover:text-[var(--color-accent)]"
    >
      Ryan Saxe
    </a>

    <div class="flex items-center gap-5">
      <a
        href="/about"
        class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        About
      </a>
      <a
        href="/resume.pdf"
        target="_blank"
        class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        Resume
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
