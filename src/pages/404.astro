---
import PageLayout from "@/layouts/PageLayout.astro";
---

<PageLayout title="Not Found — Ryan Saxe" description="Page not found">
  <div class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="mb-2 font-[var(--font-mono)] text-sm text-[var(--color-text-faint)]">404</p>
    <h1 class="mb-4 font-[var(--font-serif)] text-2xl font-bold text-[var(--color-text)]">
      Page not found
    </h1>
    <a href="/" class="text-sm text-[var(--color-accent)] hover:underline">
      &larr; Back home
    </a>
  </div>
</PageLayout>
