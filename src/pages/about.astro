---
import PageLayout from "@/layouts/PageLayout.astro";
import Timeline from "@/components/Timeline.astro";
---

<PageLayout title="About — Ryan Saxe" description="ML engineer, MTG competitor, and New York dancer.">
  <div class="mx-auto max-w-3xl px-6 pt-8 pb-16">
    <!-- Hero -->
    <section class="mb-14 flex flex-col gap-8 sm:flex-row sm:items-start">
      <img
        src="/images/headshot.jpg"
        alt="Ryan Saxe"
        class="h-36 w-36 flex-shrink-0 rounded-2xl object-cover"
      />
      <div>
        <h1 class="mb-1 font-[var(--font-serif)] text-3xl font-bold text-[var(--color-text)]">
          Ryan Saxe
        </h1>
        <p class="mb-4 text-[var(--color-text-muted)]">
          Global Principal Data Scientist at AB-InBev
        </p>
        <p class="leading-relaxed text-[var(--color-text-muted)]">
          I build machine learning systems by day, dance in New York City by night, and
          travel the world to play Magic: the Gathering. I built an
          <a
            href="https://github.com/RyanSaxe/mtg"
            target="_blank"
            class="text-[var(--color-accent)] hover:underline">AI drafting bot for MTG</a
          > that reached rank #27 in the world.
        </p>

        <div class="mt-4 flex gap-4">
          {
            [
              { href: "https://github.com/RyanSaxe", label: "GitHub" },
              { href: "https://x.com/rcsaxe", label: "X" },
              { href: "https://linkedin.com/in/ryancsaxe", label: "LinkedIn" },
            ].map((link) => (
              <a
                href={link.href}
                target="_blank"
                class="text-sm text-[var(--color-text-faint)] transition-colors hover:text-[var(--color-accent)]"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section>
      <h2 class="mb-6 font-[var(--font-serif)] text-xl font-semibold text-[var(--color-text)]">
        Experience & Education
      </h2>
      <Timeline />
    </section>
  </div>
</PageLayout>
