---
import PageLayout from "@/layouts/PageLayout.astro";
import Timeline from "@/components/Timeline.astro";
---

<PageLayout title="About — Ryan Saxe" description="Data scientist, ML researcher, and MTG AI builder">
  <!-- Hero -->
  <section class="mb-16 flex flex-col items-center gap-8 sm:flex-row sm:items-start">
    <img
      src="/images/headshot.jpg"
      alt="Ryan Saxe"
      class="h-40 w-40 flex-shrink-0 rounded-full object-cover ring-2 ring-[var(--color-accent)]/30"
    />
    <div>
      <h1
        class="mb-2 text-3xl font-bold text-white sm:text-4xl light:text-[var(--color-text-light)]"
      >
        Ryan Saxe
      </h1>
      <p class="mb-4 text-lg text-[var(--color-accent)]">Global Principal Data Scientist</p>
      <p class="leading-relaxed text-gray-400 light:text-gray-600">
        I spend my days building machine learning systems at scale and my nights dancing in New York
        City and traveling to play Magic: the Gathering. I built an
        <a
          href="https://github.com/RyanSaxe/mtg"
          target="_blank"
          class="text-[var(--color-accent)] hover:underline">AI drafting bot for MTG</a
        > that reached rank #27 in the world — the first case of AI successfully competing in the
        game.
      </p>

      <!-- Social links -->
      <div class="mt-4 flex gap-4">
        <a
          href="https://github.com/RyanSaxe"
          target="_blank"
          class="text-sm text-gray-400 transition-colors hover:text-[var(--color-accent)]"
          >GitHub</a
        >
        <a
          href="https://x.com/rcsaxe"
          target="_blank"
          class="text-sm text-gray-400 transition-colors hover:text-[var(--color-accent)]">X</a
        >
        <a
          href="https://linkedin.com/in/ryancsaxe"
          target="_blank"
          class="text-sm text-gray-400 transition-colors hover:text-[var(--color-accent)]"
          >LinkedIn</a
        >
        <a
          href="/resume.pdf"
          target="_blank"
          class="text-sm text-gray-400 transition-colors hover:text-[var(--color-accent)]"
          >Resume</a
        >
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section>
    <h2
      class="mb-8 text-2xl font-bold text-white light:text-[var(--color-text-light)]"
    >
      Experience & Education
    </h2>
    <Timeline />
  </section>
</PageLayout>
